# Copy to .env and fill in. Never commit .env.

# Required for the web chatbot example
OPENAI_API_KEY=sk-your-key-here

# Optional
OPENAI_MODEL=gpt-4o-mini

# Optional: override trace DB (otherwise web_chatbot sets repo_root/examples/traces.db in-process)
# ROOMY_DB_PATH=/absolute/path/to/traces.db
